# CryptoGuard-R Environment Configuration
# Copy this file to .env and fill in values. Never commit .env to version control.

# Application
APP_NAME=CryptoGuard-R
APP_ENV=development
DEBUG=false

# Server
HOST=0.0.0.0
PORT=8000

# Database (SQLite path)
DATABASE_URL=sqlite:///./cryptoguard.db

# Security - Generate unique values for production
SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# AI Model
MODEL_PATH=./models/phishing_model.pkl
BERT_MODEL=bert-base-uncased

# Crypto Keys (paths - generated at runtime if not exist)
RSA_PRIVATE_KEY_PATH=./keys/rsa_private.pem
RSA_PUBLIC_KEY_PATH=./keys/rsa_public.pem
